rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read-only access to certificate verification documents
    match /certificates/{certId} {
      allow read: if resource.data.status == 'active' || resource.data.status == 'revoked';
      // Allow writes only via backend - disallow client-side writes
      allow create, update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

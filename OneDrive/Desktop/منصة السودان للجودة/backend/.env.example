# Example backend environment file (DO NOT commit real secrets)
# Copy this file to 'backend/.env' and replace placeholders with real values.

# MongoDB connection string (include database name)
# Example:
# MONGODB_URI="mongodb+srv://<DB_DAOUD>:<DB_PASSWORD>@cluster0.5xftvcs.mongodb.net/<DB_NAME>?retryWrites=true&w=majority"
MONGODB_URI="mongodb+srv://DAOUD:YOUR_PASSWORD@cluster0.5xftvcs.mongodb.net/sudan_quality?retryWrites=true&w=majority"

# Frontend URL (used to build verify links)
FRONTEND_URL="http://localhost:5173"

# API key to protect certificate creation endpoint. Set a strong random value.
CERT_API_KEY="replace_with_a_strong_api_key"
